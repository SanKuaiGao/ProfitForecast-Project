{
  "name": "market-sales-forecast-demo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "desktop": "concurrently \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win --x64",
    "package:linux": "npm run build && electron-builder --linux",
    "package:win:portable": "npm run build && electron-builder --win portable --x64"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "wait-on": "^8.0.3"
  },
  "main": "electron-main.js",
  "description": "Profit forecast desktop app with revenue, cost, and regression pages.",
  "author": "OpenAI"
}
